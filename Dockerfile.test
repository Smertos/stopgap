# syntax=docker/dockerfile:1.22
FROM postgres:17

ARG STOPGAP_EXT_URL="https://github.com/Smertos/stopgap/releases/download/ext-v0.1.4/stopgap-extensions-pg17.zip"

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends curl unzip ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /tmp/stopgap-ext

RUN --mount=type=cache,target=/root/.cache,sharing=locked \
    curl -fsSL "$STOPGAP_EXT_URL" -o stopgap-extensions-pg17.zip && \
    unzip -q stopgap-extensions-pg17.zip && \
    cp plts.so /usr/lib/postgresql/17/lib/ && \
    cp stopgap.so /usr/lib/postgresql/17/lib/ && \
    cp plts.control /usr/share/postgresql/17/extension/ && \
    cp stopgap.control /usr/share/postgresql/17/extension/ && \
    cp plts*.sql /usr/share/postgresql/17/extension/ && \
    cp stopgap*.sql /usr/share/postgresql/17/extension/ && \
    rm -rf /tmp/stopgap-ext

# Initialize with extensions
RUN printf '%s\n' "CREATE EXTENSION IF NOT EXISTS plts;" > /docker-entrypoint-initdb.d/01-plts.sql && \
    printf '%s\n' "CREATE EXTENSION IF NOT EXISTS stopgap;" > /docker-entrypoint-initdb.d/02-stopgap.sql

USER postgres
